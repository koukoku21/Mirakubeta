# ─── Database (Railway) ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/miraku

# ─── Redis (Railway) ─────────────────────────────────────────────
REDIS_URL=redis://default:password@host:6379

# ─── SMS OTP (Mobizon KZ) ────────────────────────────────────────
MOBIZON_API_KEY=
MOBIZON_SENDER=Miraku

# ─── Push (Firebase FCM) ─────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Files (Cloudflare R2) ───────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=miraku-media
R2_PUBLIC_URL=https://media.miraku.kz

# ─── 2GIS Geocoding ──────────────────────────────────────────────
TWOGIS_API_KEY=

# ─── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Admin ───────────────────────────────────────────────────────
ADMIN_SECRET=change_me_in_production

# ─── App ─────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
